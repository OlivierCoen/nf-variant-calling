process {

    withName: BCFTOOLS_SORT_PER_CHUNK {
        tag = { "${input.simpleName} - ${meta.type}" }
        ext.prefix = { "${input.baseName - '.vcf'}.sorted.bcf" }
        ext.args   = { [
            "--output-type b"
            ].join(" ").trim()
        }
    }

    withName: BCFTOOLS_SORT_ALL {
        tag = { "${input.simpleName} - ${meta.type}" }
        label = { 'process_high' }
        ext.prefix = { "${input.baseName - '.bcf'}.sorted.vcf" }
        ext.args   = { [
            "--output-type z"
            ].join(" ").trim()
        }
    }


    withName: BCFTOOLS_INDEX {
        ext.args = { [
                "--tbi"
            ].join(" ").trim()
        }
    }

    withName: SURVIVOR_MERGE { // exactly 6 arguments needed in args
        ext.args = { [
                "1000",
                "1",
                "1",
                "1",
                "0",
                "30"
            ].join(" ").trim()
        }
        publishDir = [
            path: { "${params.outdir}/variants/merged/" },
            mode: params.publish_dir_mode,
        ]
    }

}
